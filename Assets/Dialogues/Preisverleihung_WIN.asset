--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a09710a68f3b04843a405d33a0731aa3, type: 3}
  m_Name: Preisverleihung_WIN
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  dialogues:
  - dialogueText: "Ladies and Gentlemen,\r\nthis year\u2019s competition was another
      fierce battle with all teams racing neck to neck. Like in recent years there
      were two standout candidates, your_team and enemy_team. They both poured their
      heart and soul into their games, pulled many allnighters and funded the local
      caffeine industry, but there can only be one winner. It is an honor to announce
      this year\u2019s winner... "
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: enemy_team!
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: 'Wow what an upset! After so many years of losses, who could have
      thought enemy_team would come out on top? '
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: "How ... How could this happen? I don\u2019t understand."
    voiceClip: {fileID: 0}
    character: 2
  - dialogueText: I guess my back is not strong enough to carry all of you through
      this
    voiceClip: {fileID: 0}
    character: 3
  - dialogueText: "It\u2019s all because of that loser..."
    voiceClip: {fileID: 0}
    character: 4
  - dialogueText: Ah shucks ... well we tried our best at least.
    voiceClip: {fileID: 0}
    character: 5
  - dialogueText: Stay tuned for the competition next year
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: Afterwards you meet the enemy team.
    voiceClip: {fileID: 0}
    character: 0
  - dialogueText: Good Job, you did well. Now take the money and get out of my sight.
      If I hear you telling anyone about you, even the rat in your apartment, we
      will come for you.
    voiceClip: {fileID: 0}
    character: 6
