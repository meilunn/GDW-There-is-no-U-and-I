  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a09710a68f3b04843a405d33a0731aa3, type: 3}
  m_Name: Preisverleihung_WIN
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  dialogues:
  - dialogueText: "Ladies and Gentlemen,\r\nthis year\u2019s competition was another
      fierce battle with all teams racing neck to neck. Like in recent years there
      were two standout candidates, your_team and enemy_team. They both poured their
      heart and soul into their games, pulled many allnighters and funded the local
      caffeine industry, but there can only be one winner. It is an honor to announce
      this year\u2019s winner... "
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: your_team!
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: 'As expected, the champions secure the win once again this year,
      keeping them on top and defending their title.

'
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: Never doubted you guys once. Great Job Team!
    voiceClip: {fileID: 0}
    character: 2
  - dialogueText: I guess the accumulated 6 hours of sleep were worth it in the end...
    voiceClip: {fileID: 0}
    character: 3
  - dialogueText: easy, peasy!
    voiceClip: {fileID: 0}
    character: 4
  - dialogueText: That calls for a party!
    voiceClip: {fileID: 0}
    character: 5
  - dialogueText: Stay tuned for the competition next year
    voiceClip: {fileID: 0}
    character: 7
  - dialogueText: Afterwards you meet the enemy team.
    voiceClip: {fileID: 0}
    character: 0
  - dialogueText: "Player we had a Deal. You broke that Deal. I don\u2019t like liars.
      And you know what we do with liars? Well you\u2019ll find out soon enough"
    voiceClip: {fileID: 0}
    character: 0
