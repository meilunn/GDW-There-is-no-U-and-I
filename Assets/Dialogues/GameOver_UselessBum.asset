  m_Name: GameOver_UselessBum
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  dialogues:
  - dialogueText: "You haven\u2019t managed to complete the easiest tasks here, you\u2019re
      never gonna make it.\r\nI didn\u2019t have a lot of expectations of you, but
      you managed to disappoint me either way. You should learn a thing or two from
      my niece.\r\n"
    voiceClip: {fileID: 0}
    character: 2
  - dialogueText: One less disturbance to my peace.
    voiceClip: {fileID: 0}
    character: 3
  - dialogueText: I really liked working with you, but some things are not meant
      to be.
    voiceClip: {fileID: 0}
    character: 5
  - dialogueText: Bye-bye :P
    voiceClip: {fileID: 0}
    character: 4
